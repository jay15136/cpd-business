<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Default document: redirect root to web/dashboard.html -->
    <defaultDocument>
      <files>
        <clear />
        <add value="web/dashboard.html" />
      </files>
    </defaultDocument>

    <!-- MIME types for files IIS may not serve by default -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <remove fileExtension=".css" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <remove fileExtension=".pdf" />
      <mimeMap fileExtension=".pdf" mimeType="application/pdf" />
      <remove fileExtension=".csv" />
      <mimeMap fileExtension=".csv" mimeType="text/csv" />
      <remove fileExtension=".docx" />
      <mimeMap fileExtension=".docx" mimeType="application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>

    <!-- Disable directory browsing globally; /docs/ overrides this below -->
    <directoryBrowse enabled="false" />

    <!-- ============================================================
         AUTHENTICATION: Windows Authentication (Integrated)
         Requires IIS role feature "Windows Authentication" installed.
         Anonymous Authentication is disabled — every request must
         present a valid Windows/domain credential (NTLM or Kerberos).
         Domain-joined clients authenticate transparently with no prompt.
         ============================================================ -->
    <security>
      <authentication>
        <anonymousAuthentication enabled="false" />
        <windowsAuthentication enabled="true" />
      </authentication>

      <!-- ============================================================
           NETWORK: Local Network Only Access
           Denies all requests by default, then whitelists:
             - Localhost (127.0.0.1, ::1)
             - Private RFC 1918 ranges (192.168.x.x, 10.x.x.x, 172.16-31.x.x)
           Any request from a public IP address is rejected with 403 Forbidden.
           REQUIRES: IIS Role Feature "IP and Domain Restrictions"
           ============================================================ -->
      <ipSecurity allowUnlisted="false" denyAction="Forbidden">
        <!-- Localhost -->
        <add ipAddress="127.0.0.1" allowed="true" />
        <!-- Private: 10.0.0.0/8 -->
        <add ipAddress="10.0.0.0" subnetMask="255.0.0.0" allowed="true" />
        <!-- Private: 172.16.0.0/12 -->
        <add ipAddress="172.16.0.0" subnetMask="255.240.0.0" allowed="true" />
        <!-- Private: 192.168.0.0/16 -->
        <add ipAddress="192.168.0.0" subnetMask="255.255.0.0" allowed="true" />
      </ipSecurity>
      <requestFiltering>
        <hiddenSegments>
          <add segment="src" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".bak" allowed="false" />
          <add fileExtension=".bat" allowed="false" />
          <add fileExtension=".java" allowed="false" />
          <add fileExtension=".config" allowed="false" />
        </fileExtensions>
        <!-- Block requests with suspicious query strings -->
        <denyQueryStringSequences>
          <add sequence=".." />
          <add sequence=":" />
        </denyQueryStringSequences>
        <!-- Limit request sizes -->
        <requestLimits maxAllowedContentLength="2097152" maxUrl="2048" maxQueryString="1024" />
      </requestFiltering>
    </security>

    <!-- URL Rewrite: redirect root to dashboard -->
    <rewrite>
      <rules>
        <rule name="Root to Dashboard" stopProcessing="true">
          <match url="^$" />
          <action type="Redirect" url="web/dashboard.html" redirectType="Found" />
        </rule>
      </rules>
    </rewrite>

    <!-- Cache static assets for performance -->
    <caching>
      <profiles>
        <add extension=".css" policy="CacheUntilChange" />
        <add extension=".js" policy="CacheUntilChange" />
        <add extension=".png" policy="CacheUntilChange" />
        <add extension=".jpg" policy="CacheUntilChange" />
      </profiles>
    </caching>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- Classic ASP settings for the api/ folder -->
    <asp>
      <session allowSessionState="false" />
      <limits requestEntityAllowed="true" maxRequestEntityAllowed="2097152" />
    </asp>

  </system.webServer>

  <!-- ============================================================
       /docs/ — Enable directory browsing for internal documents.
       Inherits Windows Authentication from the parent site.
       Officers and supervisors can click to download .docx files.
       ============================================================ -->
  <location path="docs">
    <system.webServer>
      <directoryBrowse enabled="true" />
      <security>
        <requestFiltering>
          <!-- Allow only .docx and .pdf in /docs/ -->
          <fileExtensions allowUnlisted="false">
            <add fileExtension=".docx" allowed="true" />
            <add fileExtension=".pdf"  allowed="true" />
          </fileExtensions>
        </requestFiltering>
      </security>
    </system.webServer>
  </location>

</configuration>
